{
  "name": "dnd-combat-companion",
  "version": "1.0.0",
  "description": "Log of Beholding — voice-activated TTRPG reference overlay",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist": "electron-builder",
    "build-data": "ts-node --esm scripts/build-data.ts",
    "build-spells-2024": "ts-node -P tsconfig.node.json scripts/build-spells-srd2024.ts",
    "build-library": "ts-node -P tsconfig.node.json scripts/build-from-library.ts"
  },
  "dependencies": {
    "vosk": "^0.3.39",
    "zustand": "^5.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^40.6.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.2"
  },
  "build": {
    "appId": "com.logofbeholding.app",
    "productName": "Log of Beholding",
    "icon": "resources/icon.png",
    "asar": true,
    "npmRebuild": false,
    "asarUnpack": [
      "out/main/speech-worker.js",
      "node_modules/vosk/**",
      "node_modules/ffi-napi/**",
      "node_modules/ref-napi/**",
      "node_modules/ref-struct-di/**",
      "node_modules/ref-union-di/**"
    ],
    "extraResources": [
      { "from": "resources/vosk-model", "to": "vosk-model" },
      { "from": "src/renderer/data", "to": "data", "filter": ["*.json"] }
    ],
    "files": [
      "out/**"
    ],
    "win": {
      "target": [
        { "target": "dir", "arch": ["x64"] }
      ],
      "sign": false,
      "signingHashAlgorithms": []
    }
  }
}
